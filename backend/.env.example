# ── ClinicalGuard Backend — Environment Variables Template ───────────
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit your real .env to version control.

# ── MongoDB ────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=clinicalguard

# ── JWT Authentication ─────────────────────────────────────────────────
# REQUIRED — server refuses to start without this set to a real secret.
# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_YOUR_GENERATED_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Google Gemini AI ────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Leave empty to disable AI reasoning (Gemini is optional).
GEMINI_API_KEY=

# ── Polygon Blockchain (Optional) ──────────────────────────────────────
# Leave BOTH empty to run in explicit STUB mode (development/demo).
# STUB mode is visible and labelled — it never pretends to be real.
# To enable live anchoring:
#   1. Deploy ClinicalTrialIntegrity.sol to Polygon Amoy testnet.
#   2. Export ABI to smart-contract/abi.json.
#   3. Set the RPC URL from Alchemy/Infura and contract address below.
POLYGON_RPC_URL=
CONTRACT_ADDRESS=

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000
